<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Coleta Seletiva</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../../partials/header') %>

  <main class="container">
    <div class="page-header">
      <h1 class="page-title">Editar Agendamento</h1>
      <a href="/agendamentos" class="btn btn-secondary">&#8592; Voltar</a>
    </div>

    <div class="form-card">
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form action="/agendamentos/<%= agendamento.id %>?_method=PUT" method="POST" class="crud-form">
        <div class="form-group">
          <label for="pontoColetaId">Ponto de Coleta <span class="required">*</span></label>
          <select id="pontoColetaId" name="pontoColetaId" required>
            <option value="">Selecione um ponto de coleta</option>
            <% pontos.forEach(ponto => { %>
              <option value="<%= ponto.id %>" <%= String(agendamento.pontoColetaId) === String(ponto.id) ? 'selected' : '' %>>
                <%= ponto.nome %> — <%= ponto.bairro %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="residuoId">Resíduo <span class="required">*</span></label>
          <select id="residuoId" name="residuoId" required>
            <option value="">Selecione um resíduo</option>
            <% residuos.forEach(residuo => { %>
              <option value="<%= residuo.id %>" <%= String(agendamento.residuoId) === String(residuo.id) ? 'selected' : '' %>>
                <%= residuo.nome %> (<%= residuo.categoria %>)
              </option>
            <% }) %>
          </select>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="data">Data <span class="required">*</span></label>
            <input
              type="date"
              id="data"
              name="data"
              value="<%= agendamento.data %>"
              required
            >
          </div>

          <div class="form-group">
            <label for="horario">Horário <span class="required">*</span></label>
            <input
              type="time"
              id="horario"
              name="horario"
              value="<%= agendamento.horario %>"
              required
            >
          </div>
        </div>

        <div class="form-group">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="pendente"   <%= agendamento.status === 'pendente'   ? 'selected' : '' %>>Pendente</option>
            <option value="confirmado" <%= agendamento.status === 'confirmado' ? 'selected' : '' %>>Confirmado</option>
            <option value="cancelado"  <%= agendamento.status === 'cancelado'  ? 'selected' : '' %>>Cancelado</option>
            <option value="concluido"  <%= agendamento.status === 'concluido'  ? 'selected' : '' %>>Concluído</option>
          </select>
        </div>

        <div class="form-actions">
          <a href="/agendamentos" class="btn btn-secondary">Cancelar</a>
          <button type="submit" class="btn btn-primary">Atualizar</button>
        </div>
      </form>
    </div>
  </main>

  <%- include('../../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
