<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Coleta Seletiva</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container">

    <div class="welcome-card">
      <div>
        <h1>Bem-vindo, <%= user.nome %>!</h1>
        <p>
          Você está autenticado como
          <span class="welcome-badge"><%= user.role === 'admin' ? 'Administrador' : 'Usuário' %></span>
        </p>
      </div>
      <div class="welcome-card-icon">♻</div>
    </div>

    <div class="stats-grid">
      <div class="stat-card stat-card--green">
        <div class="stat-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
          </svg>
        </div>
        <div class="stat-card__body">
          <span class="stat-card__value"><%= stats.totalUsuarios %></span>
          <span class="stat-card__label">Usuários</span>
        </div>
        <a href="#" class="stat-card__link">Ver todos</a>
      </div>

      <div class="stat-card stat-card--orange">
        <div class="stat-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15v-4H7l5-8v4h4l-5 8z"/>
          </svg>
        </div>
        <div class="stat-card__body">
          <span class="stat-card__value"><%= stats.totalResiduos %></span>
          <span class="stat-card__label">Resíduos</span>
        </div>
        <a href="/residuos" class="stat-card__link">Ver todos</a>
      </div>

      <div class="stat-card stat-card--blue">
        <div class="stat-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
        </div>
        <div class="stat-card__body">
          <span class="stat-card__value"><%= stats.totalPontosColeta %></span>
          <span class="stat-card__label">Pontos de Coleta</span>
        </div>
        <a href="/pontos-coleta" class="stat-card__link">Ver todos</a>
      </div>

      <div class="stat-card stat-card--purple">
        <div class="stat-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/>
          </svg>
        </div>
        <div class="stat-card__body">
          <span class="stat-card__value"><%= stats.totalAgendamentos %></span>
          <span class="stat-card__label">Agendamentos</span>
        </div>
        <a href="/agendamentos" class="stat-card__link">Ver todos</a>
      </div>
    </div>

    <div class="quick-access">
      <h2 class="section-title">Acesso Rápido</h2>
      <div class="quick-links">
        <a href="/residuos/novo" class="quick-link">
          <span class="quick-link__icon">+</span>
          Novo Resíduo
        </a>
        <a href="/pontos-coleta/novo" class="quick-link">
          <span class="quick-link__icon">+</span>
          Novo Ponto de Coleta
        </a>
        <a href="/agendamentos/novo" class="quick-link">
          <span class="quick-link__icon">+</span>
          Novo Agendamento
        </a>
      </div>
    </div>

  </main>

  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
